#!/bin/bash
set -e

tpl=$(realpath $0).tpl
cwd=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
imageDir=$(dirname $cwd)
mysqlImage=$(cat ${imageDir}/Dockerfile | grep FROM | sed 's/FROM //')
mysqlDataImage="$1"
pid=${BASHPID}

source "${cwd}/../../_tools/helpers/common.sh"

# destroy containers and remove trash
cleanup() {
     docker-compose -p "test${pid}" -f "${cwd}/docker-compose-${pid}.yml" stop &>/dev/null
     docker-compose -p "test${pid}" -f "${cwd}/docker-compose-${pid}.yml" rm -fv &>/dev/null

     rm -f "${cwd}/docker-compose-${pid}.yml"
}

trap cleanup EXIT

# helper method to run actuall tests
testQuery() {
    mysql_ip="$1"
    user="$2"
    password="$3"
    query="$4"

    echo -n "Testing query: '$query' .... "
    if ! docker exec "test${pid}-mysql-1" bash -c "mysql -h ${mysql_ip} -u ${user} -p${password} -e \"${query}\"" >/dev/null; then
		echo "ERROR"
        exit 1
    fi

	echo "OK"
}

# start mysql server container with data volume from the tested image
cat $tpl | sed \
-e "s#__MYSQL_IMAGE__#${mysqlImage}#" \
-e "s#__MYSQL_DATA_IMAGE__#${mysqlDataImage}#" \
> "${cwd}/docker-compose-${pid}.yml"

echo "Starting containers..."
if ! docker-compose -p "test${pid}" -f "${cwd}/docker-compose-${pid}.yml" up -d; then
    echo "ERROR: Failed to start containers"
    docker-compose -p "test${pid}" -f "${cwd}/docker-compose-${pid}.yml" logs
    exit 1
fi

echo "Waiting for MySQL to be ready..."
# Wait for MySQL to be ready by checking from inside the container
for i in $(seq 1 30); do
    if docker exec "test${pid}-mysql-1" mysqladmin ping -h localhost --silent 2>/dev/null; then
        echo "MySQL ready after $i attempts"
        break
    fi
    if [ $i -eq 30 ]; then
        echo "ERROR: MySQL not ready after 30 attempts"
        docker logs "test${pid}-mysql-1" 2>&1 | tail -30
        exit 1
    fi
    sleep 1
done

# actual tests
testQuery "localhost" project project "use project"
testQuery "localhost" project project "show databases"
testQuery "localhost" project project "create database project_test"
testQuery "localhost" project project "use project_test"

