#!/bin/bash
#
# xdebug-config - Configure xdebug across Docker Compose project containers
#
# Supports two modes:
#   1. Modern: Uses Docker API via curl (requires docker socket)
#   2. Legacy: Uses netcat to communicate with containers (linker-based)
#
# The script auto-detects which mode to use based on available resources.
#
# Usage:
#   xdebug-config enable    # Enable xdebug for host IDE
#   xdebug-config disable   # Disable xdebug
#   xdebug-config <host>    # Enable xdebug pointing to specific host
#   xdebug-config daemon    # Legacy: start daemon listener (for linker setups)
#

# === Configuration ===
DOCKER_SOCKET="${DOCKER_SOCKET:-/var/run/docker.sock}"
DOCKER_API="http://localhost"
LEGACY_PORT=4096

# === Helper Functions ===

function print_help() {
	cat <<'EOF'
xdebug-config - Configure xdebug across Docker Compose project containers

Usage:
    xdebug-config enable|default|host   Enable xdebug for host IDE
    xdebug-config disable               Disable xdebug in all containers
    xdebug-config <hostname>            Enable xdebug pointing to container
    xdebug-config daemon                Legacy mode: start daemon listener

Examples:
    xdebug-config enable                # For IDE on host machine
    xdebug-config disable               # Turn off xdebug
    xdebug-config dev                   # Point to 'dev' container

Modern mode requires Docker socket access.
Legacy mode (with linker) uses netcat for container communication.
EOF
}

# === Mode Detection ===

function has_docker_socket() {
	[ -S "$DOCKER_SOCKET" ] && command -v curl &>/dev/null && command -v jq &>/dev/null
}

function has_legacy_hosts() {
	# Check for Docker link-style hostnames in /etc/hosts (e.g., projectname_service_1 or service_1)
	grep -qE "[a-zA-Z0-9_-]+_[a-zA-Z0-9_-]+_[0-9]+" /etc/hosts 2>/dev/null
}

# === Modern Mode (Docker API) ===

function docker_api() {
	local method="$1"
	local endpoint="$2"
	local data="$3"

	if [ -n "$data" ]; then
		curl -s --unix-socket "$DOCKER_SOCKET" -X "$method" \
			-H "Content-Type: application/json" \
			-d "$data" \
			"${DOCKER_API}${endpoint}"
	else
		curl -s --unix-socket "$DOCKER_SOCKET" -X "$method" \
			"${DOCKER_API}${endpoint}"
	fi
}

function docker_exec() {
	local container_id="$1"
	shift
	local cmd="$*"

	local exec_id
	exec_id=$(docker_api POST "/containers/${container_id}/exec" \
		"{\"AttachStdout\":true,\"AttachStderr\":true,\"Cmd\":[\"sh\",\"-c\",\"$cmd\"]}" \
		| jq -r '.Id // empty')

	if [ -z "$exec_id" ]; then
		return 1
	fi

	docker_api POST "/exec/${exec_id}/start" '{"Detach":false,"Tty":false}' 2>/dev/null
}

function get_project_name() {
	if [ -f /.dockerenv ]; then
		local container_id=""

		# Method 1: cgroups v1 - container ID directly in cgroup path
		if [ -z "$container_id" ] && [ -f /proc/self/cgroup ]; then
			container_id=$(grep -oE '[0-9a-f]{64}' /proc/self/cgroup 2>/dev/null | head -1)
		fi

		# Method 2: mountinfo - container ID in /docker/containers/ path (works on both v1 and v2)
		if [ -z "$container_id" ] && [ -f /proc/self/mountinfo ]; then
			container_id=$(sed -n 's/.*\/containers\/\([0-9a-f]\{64\}\).*/\1/p' /proc/self/mountinfo 2>/dev/null | head -1)
		fi

		# Method 3: hostname - Docker sets this to short container ID by default
		if [ -z "$container_id" ]; then
			container_id=$(cat /etc/hostname 2>/dev/null || hostname)
		fi

		if [ -n "$container_id" ]; then
			local container_json project container_name
			container_json=$(docker_api GET "/containers/${container_id}/json" 2>/dev/null)

			# Check if we got a valid response
			if [ -n "$container_json" ]; then
				# Try getting project from compose label
				project=$(echo "$container_json" | jq -r '.Config.Labels["com.docker.compose.project"] // empty' 2>/dev/null)
				if [ -n "$project" ]; then
					echo "$project"
					return
				fi

				# Fallback: extract project from container name (format: projectname-servicename-1 or projectname_servicename_1)
				container_name=$(echo "$container_json" | jq -r '.Name // empty' 2>/dev/null | sed 's/^\///')
				if [ -n "$container_name" ]; then
					# Try hyphen format first (docker compose v2): project-service-1
					# Use greedy match (.*) to handle project names containing hyphens
					project=$(echo "$container_name" | sed -n 's/\(.*\)-[^-]*-[0-9]*$/\1/p')
					if [ -n "$project" ]; then
						echo "$project"
						return
					fi
					# Try underscore format (docker-compose v1): project_service_1
					# Use greedy match (.*) to handle project names containing underscores
					project=$(echo "$container_name" | sed -n 's/\(.*\)_[^_]*_[0-9]*$/\1/p')
					if [ -n "$project" ]; then
						echo "$project"
						return
					fi
				fi
			fi
		fi
	fi

	if [ -n "$COMPOSE_PROJECT_NAME" ]; then
		echo "$COMPOSE_PROJECT_NAME"
		return
	fi

	echo ""
}

function get_php_containers() {
	local project="$1"

	docker_api GET "/containers/json?filters=%7B%22label%22%3A%5B%22com.docker.compose.project%3D${project}%22%5D%7D" \
		| jq -r '.[].Id' \
		| while read -r container_id; do
			if docker_exec "$container_id" "ls /etc/php/*/mods-available/xdebug.ini" 2>/dev/null | grep -q xdebug; then
				echo "$container_id"
			fi
		done
}

function get_container_name() {
	docker_api GET "/containers/$1/json" | jq -r '.Name // empty' | sed 's/^\///'
}

function configure_container_modern() {
	local container_id="$1"
	local action="$2"
	local target_host="$3"
	local container_name
	container_name=$(get_container_name "$container_id")

	case "$action" in
		disable)
			echo -n "$container_name: "
			docker_exec "$container_id" "phpdismod -v ALL -s ALL xdebug" >/dev/null 2>&1 || true
			docker_exec "$container_id" 'if [ -f /run/php-fpm.pid ]; then kill -HUP $(cat /run/php-fpm.pid) 2>/dev/null || true; fi' >/dev/null 2>&1 || true
			echo "xdebug disabled"
			;;
		enable)
			echo -n "$container_name: "
			docker_exec "$container_id" 'ini=$(ls /etc/php/*/mods-available/xdebug.ini 2>/dev/null | head -1); if [ -f "$ini" ]; then sed -i "/^xdebug.client_host=.*$/d" "$ini"; sed -i "s/^#xdebug.client_host=/xdebug.client_host=/" "$ini"; fi' >/dev/null 2>&1 || true
			docker_exec "$container_id" "phpenmod -v ALL -s ALL xdebug" >/dev/null 2>&1 || true
			docker_exec "$container_id" 'if [ -f /run/php-fpm.pid ]; then kill -HUP $(cat /run/php-fpm.pid) 2>/dev/null || true; fi' >/dev/null 2>&1 || true
			echo "xdebug enabled (host)"
			;;
		custom)
			echo -n "$container_name: "
			docker_exec "$container_id" "ini=\$(ls /etc/php/*/mods-available/xdebug.ini 2>/dev/null | head -1); if [ -f \"\$ini\" ]; then sed -i 's/^xdebug.client_host=/#xdebug.client_host=/' \"\$ini\"; sed -i '/^xdebug.client_host=${target_host}\$/d' \"\$ini\"; echo 'xdebug.client_host=${target_host}' >> \"\$ini\"; fi" >/dev/null 2>&1 || true
			docker_exec "$container_id" "phpenmod -v ALL -s ALL xdebug" >/dev/null 2>&1 || true
			docker_exec "$container_id" 'if [ -f /run/php-fpm.pid ]; then kill -HUP $(cat /run/php-fpm.pid) 2>/dev/null || true; fi' >/dev/null 2>&1 || true
			echo "xdebug enabled -> $target_host"
			;;
	esac
}

function run_modern() {
	local action="$1"

	local project
	project=$(get_project_name)

	if [ -z "$project" ]; then
		echo "ERROR: Could not determine Docker Compose project name." >&2
		echo "Set COMPOSE_PROJECT_NAME or run from within a compose container." >&2
		exit 1
	fi

	echo "Project: $project"
	echo "---"

	local containers
	containers=$(get_php_containers "$project")

	if [ -z "$containers" ]; then
		echo "No PHP containers found in project '$project'"
		exit 0
	fi

	local action_type target_host
	case "$action" in
		disable)
			action_type="disable"
			;;
		enable|default|host)
			action_type="enable"
			;;
		*)
			action_type="custom"
			target_host="$action"
			;;
	esac

	for container_id in $containers; do
		configure_container_modern "$container_id" "$action_type" "$target_host" &
	done
	wait

	echo "---"
	echo "Done."
}

# === Legacy Mode (Linker/Netcat) ===

function get_legacy_hosts() {
	# Match hostnames like: docker-images_php_1, php_1, etc.
	grep -oE "[a-zA-Z0-9_-]+_[a-zA-Z0-9_-]+_[0-9]+" /etc/hosts 2>/dev/null | sort -u
}

function send_legacy_config() {
	local host="$1"
	local cmd="$2"
	echo "$cmd" | nc -w1 "$host" "$LEGACY_PORT" 2>/dev/null | sed "s/^/$host\t | /"
}

function run_legacy_client() {
	local action="$1"

	echo "Using legacy mode (linker)"
	echo "---"

	for host in $(get_legacy_hosts); do
		send_legacy_config "$host" "$action" &
	done
	wait

	echo "---"
	echo "Done."
}

# === Legacy Daemon Mode ===

ini="$(echo /etc/php/*/mods-available/xdebug.ini)"

function reload_fpm() {
	if [ -f /run/php-fpm.pid ]; then
		echo "++ Reloading fpm"
		kill -SIGHUP "$(cat /run/php-fpm.pid)" 2>/dev/null || true
	fi
}

function xdebug_enable() {
	phpenmod -v ALL -s ALL xdebug 2>/dev/null || true
	reload_fpm
}

function xdebug_disable() {
	phpdismod -v ALL -s ALL xdebug 2>/dev/null || true
	reload_fpm
}

function configure_xdebug_for_host() {
	if [ -f "$ini" ]; then
		# Determine host IP: DEV_IP (from docker-compose) > fallback to 10.24.0.1 (legacy)
		local host_ip="${DEV_IP:-10.24.0.1}"
		sed -i '/^xdebug.client_host=.*$/d' "$ini"
		sed -i '/^#xdebug.client_host=/d' "$ini"
		echo "xdebug.client_host=$host_ip" >> "$ini"
	fi
}

function configure_xdebug_for_container() {
	local host="$1"
	if [ -f "$ini" ]; then
		if grep -q '^#xdebug.client_host=' "$ini"; then
			sed -i '/^xdebug.client_host=.*$/d' "$ini"
			echo "xdebug.client_host=$host" >> "$ini"
		else
			sed -i 's/^xdebug.client_host=/#xdebug.client_host=/' "$ini"
			echo "xdebug.client_host=$host" >> "$ini"
		fi
	fi
}

function handle_daemon_request() {
	read -r host
	case "$host" in
		disable)
			echo "-- xdebug disabled"
			xdebug_disable
			;;
		enable|default|host)
			echo "++ xdebug enabled for use with host IDE"
			configure_xdebug_for_host
			xdebug_enable
			;;
		*)
			echo "++ xdebug enabled for use in container '$host'"
			configure_xdebug_for_container "$host"
			xdebug_enable
			;;
	esac
}

function run_daemon() {
	echo "Starting xdebug-config daemon on port $LEGACY_PORT..."
	while true; do
		handle_daemon_request < <(nc -l -p "$LEGACY_PORT" -q1 2>/dev/null || nc -l "$LEGACY_PORT" 2>/dev/null)
	done
}

# === Main Logic ===

function main() {
	local action="$1"

	case "$action" in
		''|-h|--help|help)
			print_help
			exit 0
			;;
		daemon|deamon)
			run_daemon
			exit 0
			;;
	esac

	# Try modern mode first (Docker socket)
	if has_docker_socket; then
		run_modern "$action"
	# Fallback to legacy mode (linker/netcat)
	elif has_legacy_hosts; then
		run_legacy_client "$action"
	else
		echo "ERROR: No Docker socket and no legacy hosts found." >&2
		echo "" >&2
		echo "For modern mode: mount Docker socket to your dev container:" >&2
		echo "  volumes:" >&2
		echo "    - /var/run/docker.sock:/var/run/docker.sock" >&2
		echo "" >&2
		echo "For legacy mode: ensure linker container is running and linked." >&2
		exit 1
	fi
}

main "$@"
