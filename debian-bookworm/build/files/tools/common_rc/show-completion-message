#!/bin/bash -e

# ============================================================================
# Check DVM mode from environment variable
# Defaults to legacy for backward compatibility with old DVM setups
# ============================================================================
if [ -z "$DVM_MODE" ]; then
	DVM_MODE="legacy"
fi

# ============================================================================
# Determine DEV_URL based on DVM mode
# ============================================================================
if [ -z "$DEV_URL" ]; then
	if [[ "$DVM_MODE" == "modern" ]]; then
		# Modern mode: Extract hostname from Traefik labels in docker-compose
		# Look for web container's Traefik Host() rule
		compose_dir=$(dirname "$NFQ_PROJECT_ROOT" 2>/dev/null || echo ".")
		if [ -f "$compose_dir/docker-compose.yml" ]; then
			# Extract hostname from Host(`domain.com`) format
			DEV_URL=$(grep "Host(" "$compose_dir/docker-compose.yml" 2>/dev/null | grep -o 'Host([^)]*)' | sed 's/Host(//g; s/)//g; s/`//g' | head -1)
		fi
	fi

	# Fallback: Generate from git remote (legacy mode or if Traefik label not found)
	if [ -z "$DEV_URL" ] && [ -d "$NFQ_PROJECT_ROOT" ]; then
		DEV_URL="$(
			cd "$NFQ_PROJECT_ROOT" && \
			sudo -u project git remote -v 2>/dev/null \
			| grep 'origin\s.*\.' \
			| head -n 1 | cut -d: -f2 \
			| awk -F"/" '{slashes=$0; gsub("[^/]", "", slashes); project=substr($NF, 0, index($NF, ".git")); if(length(slashes)>1){ subgroups=$(NF-1)"."$(NF-2)}else{subgroups=$(NF-1)}; print project subgroups ".test" }'
		)"
	fi
fi

cat - <<'EOF'

   .______   .______        ______          __   _______   ______ .___________.
   |   _  \  |   _  \      /  __  \        |  | |   ____| /      ||           |
   |  |_)  | |  |_)  |    |  |  |  |       |  | |  |__   |  ,----'`---|  |----`
   |   ___/  |      /     |  |  |  | .--.  |  | |   __|  |  |         |  |
   |  |      |  |\  \----.|  `--'  | |  `--'  | |  |____ |  `----.    |  |
   | _|      | _| `._____| \______/   \______/  |_______| \______|    |__|

     _______.___________.    ___      .______     .___________. _______  _______
    /       |           |   /   \     |   _  \    |           ||   ____||       \
   |   (----`---|  |----`  /  ^  \    |  |_)  |   `---|  |----`|  |__   |  .--.  |
    \   \       |  |      /  /_\  \   |      /        |  |     |   __|  |  |  |  |
.----)   |      |  |     /  _____  \  |  |\  \----.   |  |     |  |____ |  '--'  |
|_______/       |__|    /__/     \__\ | _| `._____|   |__|     |_______||_______/


Now you can connect via http or ssh.
EOF

# Retrieve container IP address (only if not already provided by docker-compose)
if [ -z "$DEV_IP" ]; then
	DEV_IP="$(ip r | grep '^default ' | awk '{print $3}')"
fi

# For legacy mode: check if DEV_URL responds to appropriate IP address
# For modern mode: skip this check since hostname is for host machine, not container
if [[ "$DVM_MODE" != "modern" ]]; then
	if ! ping -qc 1 "$DEV_URL" 2>&1 | grep -q "($DEV_IP)"; then
		# Show error message if DEV_URL is set but not resolvable,
		# otherwise it is intended behavior, so no error
		if [ -n "$DEV_URL" ]; then
			echo "Development URL $DEV_URL is not resolvable, using fallback IP address:"
		fi
		DEV_URL="$DEV_IP"
	fi
fi

echo

# ============================================================================
# Display connection info based on DVM mode
# ============================================================================
if [[ "$DVM_MODE" == "modern" ]]; then
	# Modern Mode (Traefik + SSL)
	echo -e "\e[1;32m=== Modern Mode (Traefik + SSL) ===\e[0m"
	echo
	echo -e "\e[1mWeb Access (from host machine):\e[0m"
	echo -e "  \e[1;36mhttps://$DEV_URL/\e[0m"
	echo
	echo -e "\e[1mSSH Access (from host machine):\e[0m"
	if [ -n "$SSH_PORT" ]; then
		echo -e "  \e[1mssh -p $SSH_PORT project@$DEV_IP\e[0m"
		echo -e "  \e[90m(Port $SSH_PORT is routed via Traefik)\e[0m"
	else
		echo -e "  \e[1mssh -p 23 project@$DEV_IP\e[0m"
		echo -e "  \e[90m(Set SSH_PORT in .env to customize)\e[0m"
	fi
	echo
	echo -e "\e[33mTraefik Dashboard:\e[0m"
	echo -e "  https://traefik.dvm.nfq.lt/"
	echo
else
	# Legacy Mode (or old DVM setup without /etc/dvm-config)
	echo -e "\e[1m http://$DEV_URL/ \e[0m"
	echo " ssh project@$DEV_URL"
	echo
fi

echo
